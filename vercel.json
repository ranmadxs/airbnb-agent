{
  "builds": [
    {
      "src": "airbnb_agent/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "airbnb_agent/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "airbnb_agent/app.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
