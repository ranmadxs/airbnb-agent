# Airbnb iCal URL
AIRBNB_CALENDAR_URL=""

# Zona horaria de la propiedad (evita desfase en producción UTC). Ej: America/Santiago
TIMEZONE="America/Santiago"

# Owner phone number for logging/display
OWNER_PHONE=""

# Owner WhatsApp JID (e.g., number@s.whatsapp.net) to receive and approve summaries
OWNER_JID=""

# Provider alias from providers.json to use as a mock/real summary recipient
SUMMARY_RECEIVER_ID="tester"

# MercadoPago: para reservatinaja
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
# Link de pago estático (ej. https://link.mercadopago.cl/posadaenelbosque). Si no se define, usa posadaenelbosque por defecto.
MERCADOPAGO_LINK="https://link.mercadopago.cl/posadaenelbosque"
# Botones con valores fijos (modelo híbrido). JSON: [{"valor":19500,"link":"https://mpago.la/1sRuP77"},{"valor":22400,"link":"https://mpago.la/23E1Z2w"},{"valor":19000,"link":"https://mpago.la/2e9WCsu"}]
# MERCADOPAGO_BOTONES='[{"valor":19500,"link":"https://mpago.la/1sRuP77"},{"valor":22400,"link":"https://mpago.la/23E1Z2w"},{"valor":19000,"link":"https://mpago.la/2e9WCsu"}]'
# Para recibir notificaciones cuando se efectúe un pago: Tus integraciones > Webhooks > Pagos > URL: https://tudominio.com/api/mercadopago/webhook
